{{#js}}
require([
    'theme_boost/footer-popover',
    'core/copy_to_clipboard',
    'theme_cdc_moodle/accessibility'
], function(FooterPopover, CopyToClipboard, Accessibility) {
    FooterPopover.init();
    Accessibility.init();
});
{{/js}}
