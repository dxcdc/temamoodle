{{!
    @template tool_policy/page_agreedocs

    Template for showing to the user the policy docs to agree (overridden for Uena theme).
}}

{{#messages}}{{{.}}}{{/messages}}

<div class="terms-container">
    <!-- Progressive Wizard Steps Indicator -->
    <div class="moodle-wizard-steps mb-4">
        <div class="wizard-step completed">
            <div class="step-num"><i class="fa fa-check"></i></div>
            <div class="step-label">Ler Contratos</div>
        </div>
        <div class="wizard-connector completed"></div>
        <div class="wizard-step active">
            <div class="step-num">2</div>
            <div class="step-label">Escolher Consentimentos</div>
        </div>
        <div class="wizard-connector"></div>
        <div class="wizard-step">
            <div class="step-num">3</div>
            <div class="step-label">Preencher Cadastro</div>
        </div>
    </div>

    <form id="agreedocsform" method="post" action="{{myurl}}">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        {{#behalfuser}}
            <div class="clearfix mb-3">
                <div class="alert alert-warning">
                    {{# str }} viewconsentpageforuser, tool_policy, {{{ . }}} {{/ str }}
                </div>
            </div>
        {{/behalfuser}}

        <!-- 1. CABEÇALHO E INTRODUÇÃO -->
        <div class="clearfix mb-2">
            <h2 class="terms-title">Concordar</h2>
        </div>
        
        <div class="intro-section mb-4 p-3 border rounded bg-light">
            <h5 class="font-weight-bold text-dark mb-2">Introdução</h5>
            <p class="text-muted mb-0" style="font-size: 0.95rem; line-height: 1.5;">
                Os termos abaixo regulam o uso da plataforma de ensino a distância do CDC e o tratamento dos seus dados. Por favor, leia os contratos com atenção e faça as suas escolhas de consentimento abaixo.
            </p>
        </div>

        {{#policies}}
            <input value="{{id}}" name="listdoc[]" type="hidden">

            <!-- CAIXA DO CONTRATO COM ROLAGEM -->
            <div class="terms-box">
                <h4>{{{name}}}</h4>
                <div class="terms-content">
                    {{{summary}}}
                </div>
                <div class="agreedoc-msg mt-3 pt-2 border-top">
                    {{# str }}refertofullpolicytext, tool_policy, {{{policymodal}}} {{/ str }}
                </div>
            </div>

            <!-- SEÇÃO DE RESPOSTAS (CONFIRMAÇÃO + MULTIPLA ESCOLHA) -->
            <div class="agreement-section">
                <!-- Checkbox de Leitura -->
                <div class="mb-3 d-flex align-items-center">
                    <label class="d-flex align-items-center cursor-pointer mb-0">
                        <input type="checkbox" id="read_confirm_{{id}}" class="read-confirm-checkbox mr-2" style="width: 18px; height: 18px; accent-color: #F6A02A; cursor: pointer;" required>
                        <span class="font-weight-bold text-dark" style="font-size: 0.95rem;">Li o(s) termo(s) de {{{name}}}.</span>
                        <i class="icon fa fa-exclamation-circle text-danger fa-fw ml-1" title="{{# str }} required, core {{/ str }}" ></i>
                    </label>
                </div>

                <hr style="border-top: 1px solid #dee2e6; margin: 15px 0;">

                <!-- Botões de Rádio -->
                <div class="agreement-group">
                    <span class="agreement-label">
                        Você concorda com o(a) {{{name}}}?
                        {{^optional}}
                            <i class="icon fa fa-exclamation-circle text-danger fa-fw" title="{{# str }} required, core {{/ str }}" ></i>
                            <span class="text-danger font-weight-bold" style="font-size: 0.8rem;">(Obrigatório para prosseguir)</span>
                        {{/optional}}
                    </span>
                    
                    <div class="radio-options mt-3">
                        <label class="radio-inline radio-no d-flex align-items-center mb-0">
                            <input type="radio" name="status{{id}}" value="0" {{#versiondeclined}}checked="{{.}}"{{/versiondeclined}} required>
                            <span class="ml-2 font-weight-bold">NÃO CONCORDO</span>
                        </label>
                        <label class="radio-inline radio-yes d-flex align-items-center mb-0">
                            <input type="radio" name="status{{id}}" value="1" {{#versionagreed}}checked="{{.}}"{{/versionagreed}} required>
                            <span class="ml-2 font-weight-bold">SIM, CONCORDO</span>
                        </label>
                    </div>
                </div>
            </div>
        {{/policies}}

        <div class="mt-4 pt-3 border-top d-flex justify-content-start">
            <input type="submit" class="btn btn-primary px-5 py-2 text-uppercase font-weight-bold mr-2" name="submit" value="CONTINUAR">
            {{#cancancel}}
                <input type="submit" class="btn btn-secondary px-4 py-2 text-uppercase font-weight-bold" name="cancel" value="{{#cleanstr}} cancel {{/cleanstr}}">
            {{/cancancel}}
        </div>
    </form>
</div>

{{#js}}
// Initialise the JS for the modal window which displays the policy versions.
require(['tool_policy/policyactions'], function(ActionsMod) {
    ActionsMod.init('[data-action="view"]');
});

// Asynchronously fetch and inject the full policy text into the scrollbox
(function() {
    const loadFullPolicyTexts = function() {
        const termsBoxes = document.querySelectorAll('.terms-box');
        termsBoxes.forEach(function(box) {
            if (box.dataset.loaded) return;
            
            const link = box.querySelector('a[href*="view.php"]');
            if (link) {
                const url = link.getAttribute('href');
                fetch(url)
                    .then(response => response.text())
                    .then(html => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        // Extract Moodle's native full policy content container
                        const fullContent = doc.querySelector('.policy_document_content') || 
                                            doc.querySelector('.policy-document') || 
                                            doc.querySelector('.policy-content') ||
                                            doc.querySelector('.policy_document');
                        
                        if (fullContent) {
                            const contentDiv = box.querySelector('.terms-content');
                            if (contentDiv) {
                                contentDiv.innerHTML = fullContent.innerHTML;
                                box.dataset.loaded = "true";
                            }
                        }
                    })
                    .catch(err => console.error("Error fetching full policy content: ", err));
            }
        });
    };
    loadFullPolicyTexts();
    setTimeout(loadFullPolicyTexts, 400);
    setTimeout(loadFullPolicyTexts, 1200);
})();
{{/js}}
